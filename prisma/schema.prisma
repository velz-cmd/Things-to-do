generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title           String
  category        String   @default("money_recovery")
  company         String?
  targetValueUsd  Float
  successFeeUsd   Float    @default(0.5)
  budgetUsd       Float    @default(1.0)
  status          String   @default("created")
  merchantId      String?
  userWallet      String?
  escrowTxHash    String?
  escrowTaskId    Int?
  escrowLocked    Boolean  @default(false)
  proofHash       String?
  settlementTxHash String?
  recoveredUsd    Float    @default(0)
  executionCostUsd Float   @default(0)
  currentAgent    String?
  nextRunAt       DateTime?
  statusStartedAt DateTime?
  statusTimeoutAt DateTime?
  attentionReason String?
  intakeJson      String?
  isDemo          Boolean  @default(false)
  paused          Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  events          TaskEvent[]
  proofs          Proof[]
  microPayments   MicroPayment[]
  settlement      Settlement?
  executionCosts  ExecutionCostEvent[]
  browserProofs   BrowserProof[]
  evidenceFiles   EvidenceFile[]
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent     String
  phase     String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Proof {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         String
  source       String
  payload      String
  contentHash  String
  artifactUrl  String?
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model MicroPayment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  purpose   String
  amountUsd Float
  txHash    String?
  createdAt DateTime @default(now())
}

model Stats {
  id                    Int @id @default(1)
  moneyRecoveredUsd     Float @default(0)
  tasksCompleted        Int   @default(0)
  executionCostUsd      Float @default(0)
  subscriptionsCancelled Int  @default(0)
}

model User {
  id              String   @id
  email           String?
  displayName     String?
  authProvider    String   @default("wallet")
  walletAddress   String?
  scanWalletAddress String?
  githubUsername  String?
  githubId        String?
  gmailConnected      Boolean  @default(false)
  gmailRefreshToken   String?
  taskMemoryJson  String?
  embeddedWallet  Boolean  @default(false)
  availableUsd    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tasks           Task[]
  transactions    WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  method    String?
  amountUsd Float
  status    String   @default("completed")
  label     String?
  createdAt DateTime @default(now())
}

model Settlement {
  id                String   @id @default(cuid())
  taskId            String   @unique
  task              Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mode              String   @default("mock_arc")
  status            String   @default("not_started")
  amountUsdc        String
  executionCostUsdc String   @default("0")
  chainId           Int      @default(5042002)
  contractAddress   String?
  jobId             String?
  proofHash         String?
  createJobTxHash   String?
  approveTxHash     String?
  fundTxHash        String?
  submitProofTxHash String?
  releaseTxHash     String?
  refundTxHash      String?
  explorerUrls      Json     @default("[]")
  lastVerifiedAt    DateTime?
  error             String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model ExecutionCostEvent {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent        String
  action       String
  amountUsdc   Float
  meteringMode String   @default("offchain_metered")
  txHash       String?
  createdAt    DateTime @default(now())
}

model BrowserProof {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         String
  title        String
  path         String?
  text         String?
  artifactData String?
  hash         String
  createdAt    DateTime @default(now())
}

/// Singleton RESOLVE agent on ERC-8004 IdentityRegistry (Arc testnet)
model ResolveAgent {
  id                   String   @id @default("resolve")
  agentTokenId         String?
  registerTxHash       String?
  metadataUri          String   @default("ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei")
  reputationCount      Int      @default(0)
  lastReputationTxHash String?
  lastReputationScore  Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model EvidenceFile {
  id            String   @id @default(cuid())
  userId        String
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  fileName      String
  fileType      String
  fileSize      Int
  storagePath   String
  hash          String
  status        String   @default("uploaded")
  extractedText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Key-value app configuration (e.g. Circle wallet set ID when not in env).
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Creator / contributor wallet registry — who gets paid.
model ContributorRegistry {
  id               String   @id @default(cuid())
  platform         String?
  platformId       String?
  creatorName      String?
  walletAddress   String?
  githubUsername   String?
  githubId         String?
  musicbrainzId    String?
  exifArtist       String?
  activitypubActor String?
  verified         Boolean  @default(false)
  status           String   @default("unlinked")
  proofScore       Float    @default(0)
  claimableUsd     Float    @default(0)
  totalEarnedUsd   Float    @default(0)
  lastSeenAt       DateTime?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  pendingRewards   PendingReward[]

  @@index([platform, platformId])
  @@index([githubUsername])
  @@index([githubId])
  @@index([status])
  @@index([exifArtist])
}

/// Rewards waiting for contributor to connect wallet and claim
model PendingReward {
  id             String   @id @default(cuid())
  missionId      String
  repo           String?
  githubUsername String
  githubId       String?
  contributorId  String?
  contributor    ContributorRegistry? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  amountUsd      Float
  weight         Float
  proofHash      String
  confidence     Float
  status         String   @default("claimable")
  founderUserId  String?
  settlementId   String?
  walletAddress  String?
  claimedAt      DateTime?
  settledAt      DateTime?
  notifiedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([missionId, githubUsername])
  @@index([githubUsername])
  @@index([status])
  @@index([proofHash])
}

/// Batch distribution to multiple contributors (founder / community payouts).
model DistributionBatch {
  id             String              @id @default(cuid())
  userId         String?
  platform       String?
  status         String              @default("pending")
  totalAmountUsd Float
  payeeCount     Int
  eventCount     Int
  verifiedCount  Int                 @default(0)
  rejectedCount  Int                 @default(0)
  txHash         String?
  explorerUrl    String?
  complianceJson String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  events         DistributionEvent[]
}

model DistributionEvent {
  id           String             @id @default(cuid())
  batchId      String?
  batch        DistributionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  eventId      String
  type         String
  platform     String?
  platformId   String?
  category     String             @default("distribution")
  amountUsd    Float
  payloadJson  String
  payeeWallet  String?
  payeeName    String?
  verified     Boolean            @default(false)
  verifyReason String?
  confidence   Float?
  proofHash    String?
  createdAt    DateTime           @default(now())
}

/// Payment Layer — immutable mission settlement (no GitHub / AI logic)
model MissionSettlement {
  id             String   @id @default(cuid())
  missionId      String   @unique
  repo           String?
  treasuryAmount Float
  currency       String   @default("USDC")
  proofHash      String
  confidence     Float
  status         String   @default("CREATED")
  poolsJson      String?
  packageJson    String?
  auditHash      String?
  escrowTxHash   String?
  batchNumber    Int?
  proofJson      String?
  complianceJson String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  intents        PaymentIntent[]
  nanoPayments   SettlementNanoPayment[]
  events         PaymentEvent[]

  @@index([proofHash])
  @@index([status])
}

model PaymentIntent {
  id           String            @id @default(cuid())
  settlementId String
  settlement   MissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  wallet       String
  login        String?
  weight       Float
  amountUsd    Float
  rank         Int               @default(0)
  memoId       String?
  memoText     String?
  status       String            @default("pending")
  txHash       String?
  createdAt    DateTime          @default(now())

  @@index([wallet])
  @@index([settlementId])
}

model SettlementNanoPayment {
  id              String            @id @default(cuid())
  settlementId    String
  settlement      MissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  agentRole       String
  purpose         String
  amountUsd       Float
  recipientWallet String
  memoText        String
  txHash          String?
  status          String            @default("pending")
  createdAt       DateTime          @default(now())
}

model PaymentEvent {
  id           String             @id @default(cuid())
  settlementId String
  settlement   MissionSettlement  @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  type         String
  payloadJson  String
  createdAt    DateTime           @default(now())

  @@index([settlementId])
  @@index([type])
}
