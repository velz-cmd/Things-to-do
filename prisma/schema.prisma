generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id               String               @id @default(cuid())
  userId           String?
  user             User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  title            String
  category         String               @default("money_recovery")
  company          String?
  targetValueUsd   Float
  successFeeUsd    Float                @default(0.5)
  budgetUsd        Float                @default(1.0)
  status           String               @default("created")
  merchantId       String?
  userWallet       String?
  escrowTxHash     String?
  escrowTaskId     Int?
  escrowLocked     Boolean              @default(false)
  proofHash        String?
  settlementTxHash String?
  recoveredUsd     Float                @default(0)
  executionCostUsd Float                @default(0)
  currentAgent     String?
  nextRunAt        DateTime?
  statusStartedAt  DateTime?
  statusTimeoutAt  DateTime?
  attentionReason  String?
  intakeJson       String?
  isDemo           Boolean              @default(false)
  paused           Boolean              @default(false)
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  events           TaskEvent[]
  proofs           Proof[]
  microPayments    MicroPayment[]
  settlement       Settlement?
  executionCosts   ExecutionCostEvent[]
  browserProofs    BrowserProof[]
  evidenceFiles    EvidenceFile[]
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent     String
  phase     String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Proof {
  id          String   @id @default(cuid())
  taskId      String
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type        String
  source      String
  payload     String
  contentHash String
  artifactUrl String?
  verified    Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model MicroPayment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  purpose   String
  amountUsd Float
  txHash    String?
  createdAt DateTime @default(now())
}

model Stats {
  id                     Int   @id @default(1)
  moneyRecoveredUsd      Float @default(0)
  tasksCompleted         Int   @default(0)
  executionCostUsd       Float @default(0)
  subscriptionsCancelled Int   @default(0)
}

model User {
  id                       String                    @id
  email                    String?
  displayName              String?
  authProvider             String                    @default("wallet")
  walletAddress            String?
  scanWalletAddress        String?
  githubUsername           String?
  githubId                 String?
  gmailConnected           Boolean                   @default(false)
  gmailRefreshToken        String?
  listenbrainzUsername     String?
  listenbrainzToken        String?
  navidromeUrl             String?
  navidromeUsername        String?
  navidromePassword        String?
  jellyfinUrl              String?
  jellyfinUsername         String?
  jellyfinPassword         String?
  jellyfinAccessToken      String?
  taskMemoryJson           String?
  embeddedWallet           Boolean                   @default(false)
  selectedCapitalWallet    String                    @default("app")
  availableUsd             Float                     @default(0)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  tasks                    Task[]
  transactions             WalletTransaction[]
  resolveMissions          ResolveMission[]
  resolveEcosystems        ResolveEcosystem[]
  resolveKnowledge         ResolveKnowledgeEntry[]
  resolveTimeline          ResolveTimelineEvent[]
  communityInstalls        ResolveCommunityInstall[]
  resolvePrograms          ResolveProgram[]
  communityFundStakes      CommunityFundStake[]
  automationRules          ResolveAutomationRule[]
  earningsSnapshot         UserEarningsSnapshot?
  missionBlueprintReceipts MissionBlueprintReceipt[]
}

/**
 * App-owned reset tokens — survives email link prefetch (Supabase OTP is single-use).
 */
model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  email     String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([email])
  @@index([expiresAt])
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  method    String?
  amountUsd Float
  status    String   @default("completed")
  label     String?
  createdAt DateTime @default(now())
}

model Settlement {
  id                String    @id @default(cuid())
  taskId            String    @unique
  task              Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  mode              String    @default("mock_arc")
  status            String    @default("not_started")
  amountUsdc        String
  executionCostUsdc String    @default("0")
  chainId           Int       @default(5042002)
  contractAddress   String?
  jobId             String?
  proofHash         String?
  createJobTxHash   String?
  approveTxHash     String?
  fundTxHash        String?
  submitProofTxHash String?
  releaseTxHash     String?
  refundTxHash      String?
  explorerUrls      Json      @default("[]")
  lastVerifiedAt    DateTime?
  error             String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
}

model ExecutionCostEvent {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent        String
  action       String
  amountUsdc   Float
  meteringMode String   @default("offchain_metered")
  txHash       String?
  createdAt    DateTime @default(now())
}

model BrowserProof {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         String
  title        String
  path         String?
  text         String?
  artifactData String?
  hash         String
  createdAt    DateTime @default(now())
}

/// Singleton RESOLVE agent on ERC-8004 IdentityRegistry (Arc testnet)
model ResolveAgent {
  id                   String   @id @default("resolve")
  agentTokenId         String?
  registerTxHash       String?
  metadataUri          String   @default("ipfs://bafkreibdi6623n3xpf7ymk62ckb4bo75o3qemwkpfvp5i25j66itxvsoei")
  reputationCount      Int      @default(0)
  lastReputationTxHash String?
  lastReputationScore  Int?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model EvidenceFile {
  id            String   @id @default(cuid())
  userId        String
  taskId        String?
  task          Task?    @relation(fields: [taskId], references: [id], onDelete: SetNull)
  fileName      String
  fileType      String
  fileSize      Int
  storagePath   String
  hash          String
  status        String   @default("uploaded")
  extractedText String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

/// Key-value app configuration (e.g. Circle wallet set ID when not in env).
model AppConfig {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Creator / contributor wallet registry — who gets paid.
model ContributorRegistry {
  id               String          @id @default(cuid())
  platform         String?
  platformId       String?
  creatorName      String?
  walletAddress    String?
  githubUsername   String?
  githubId         String?
  musicbrainzId    String?
  exifArtist       String?
  activitypubActor String?
  verified         Boolean         @default(false)
  status           String          @default("unlinked")
  proofScore       Float           @default(0)
  claimableUsd     Float           @default(0)
  totalEarnedUsd   Float           @default(0)
  payoutCurrency   String          @default("USDC")
  lastSeenAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  pendingRewards   PendingReward[]

  @@index([platform, platformId])
  @@index([githubUsername])
  @@index([githubId])
  @@index([status])
  @@index([exifArtist])
}

/// Connector-agnostic Authorization Ledger (Distribution Bootstrap Part 2)
model PaymentAuthorization {
  id             String    @id @default(cuid())
  connectorId    String
  eventType      String
  missionId      String
  idempotencyKey String
  payeeKeyType   String
  payeeKey       String
  amountUsd      Float
  weight         Float     @default(0)
  proofHash      String
  confidence     Float     @default(0.85)
  status         String    @default("authorized")
  contextLabel   String?
  evidenceJson   String?
  founderUserId  String?
  settlementId   String?
  walletAddress  String?
  fulfilledAt    DateTime?
  settledAt      DateTime?
  notifiedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@unique([idempotencyKey])
  @@index([missionId])
  @@index([connectorId])
  @@index([payeeKeyType, payeeKey])
  @@index([status])
  @@index([proofHash])
}

/// Rewards waiting for contributor to connect wallet and claim
model PendingReward {
  id             String               @id @default(cuid())
  missionId      String
  repo           String?
  githubUsername String
  githubId       String?
  contributorId  String?
  contributor    ContributorRegistry? @relation(fields: [contributorId], references: [id], onDelete: SetNull)
  amountUsd      Float
  weight         Float
  proofHash      String
  confidence     Float
  status         String               @default("claimable")
  founderUserId  String?
  settlementId   String?
  walletAddress  String?
  claimedAt      DateTime?
  settledAt      DateTime?
  notifiedAt     DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  @@unique([missionId, githubUsername])
  @@index([githubUsername])
  @@index([status])
  @@index([proofHash])
}

/// Batch distribution to multiple contributors (founder / community payouts).
model DistributionBatch {
  id             String              @id @default(cuid())
  userId         String?
  platform       String?
  status         String              @default("pending")
  totalAmountUsd Float
  payeeCount     Int
  eventCount     Int
  verifiedCount  Int                 @default(0)
  rejectedCount  Int                 @default(0)
  txHash         String?
  explorerUrl    String?
  complianceJson String?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt
  events         DistributionEvent[]
}

model DistributionEvent {
  id           String             @id @default(cuid())
  batchId      String?
  batch        DistributionBatch? @relation(fields: [batchId], references: [id], onDelete: SetNull)
  eventId      String
  type         String
  platform     String?
  platformId   String?
  category     String             @default("distribution")
  amountUsd    Float
  payloadJson  String
  payeeWallet  String?
  payeeName    String?
  verified     Boolean            @default(false)
  verifyReason String?
  confidence   Float?
  proofHash    String?
  createdAt    DateTime           @default(now())
}

/// Payment Layer — immutable mission settlement (no GitHub / AI logic)
model MissionSettlement {
  id             String                  @id @default(cuid())
  missionId      String                  @unique
  repo           String?
  treasuryAmount Float
  currency       String                  @default("USDC")
  proofHash      String
  confidence     Float
  status         String                  @default("CREATED")
  poolsJson      String?
  packageJson    String?
  auditHash      String?
  escrowTxHash   String?
  batchNumber    Int?
  proofJson      String?
  complianceJson String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  intents        PaymentIntent[]
  nanoPayments   SettlementNanoPayment[]
  events         PaymentEvent[]

  @@index([proofHash])
  @@index([status])
}

model PaymentIntent {
  id           String            @id @default(cuid())
  settlementId String
  settlement   MissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  wallet       String
  login        String?
  weight       Float
  amountUsd    Float
  rank         Int               @default(0)
  memoId       String?
  memoText     String?
  status       String            @default("pending")
  txHash       String?
  createdAt    DateTime          @default(now())

  @@index([wallet])
  @@index([settlementId])
}

model SettlementNanoPayment {
  id              String            @id @default(cuid())
  settlementId    String
  settlement      MissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  agentRole       String
  purpose         String
  amountUsd       Float
  recipientWallet String
  memoText        String
  txHash          String?
  status          String            @default("pending")
  createdAt       DateTime          @default(now())
}

model PaymentEvent {
  id           String            @id @default(cuid())
  settlementId String
  settlement   MissionSettlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)
  type         String
  payloadJson  String
  createdAt    DateTime          @default(now())

  @@index([settlementId])
  @@index([type])
}

/// Mission OS — persistent economic intelligence sessions
model ResolveMission {
  id           String                  @id @default(cuid())
  userId       String
  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  title        String
  scope        String?
  status       String                  @default("created")
  capability   String?
  phase        String?
  ecosystemId  String?
  ecosystem    ResolveEcosystem?       @relation(fields: [ecosystemId], references: [id], onDelete: SetNull)
  findingCount Int                     @default(0)
  capitalUsd   Float?
  metadataJson String?
  createdAt    DateTime                @default(now())
  updatedAt    DateTime                @updatedAt
  turns        ResolveMissionTurn[]
  timeline     ResolveTimelineEvent[]
  knowledge    ResolveKnowledgeEntry[]

  @@index([userId, updatedAt])
  @@index([ecosystemId])
  @@index([status])
}

model ResolveMissionTurn {
  id           String         @id @default(cuid())
  missionId    String
  mission      ResolveMission @relation(fields: [missionId], references: [id], onDelete: Cascade)
  role         String
  text         String         @db.Text
  phase        String?
  capability   String?
  findingsJson String?        @db.Text
  actionsJson  String?        @db.Text
  reportJson   String?        @db.Text
  payloadJson  String?        @db.Text
  sortOrder    Int
  createdAt    DateTime       @default(now())

  @@index([missionId, sortOrder])
}

/// Mission Blueprint decision receipts — shareable across devices (Phase 6)
model MissionBlueprintReceipt {
  id             String   @id
  userId         String?
  user           User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  communitySlug  String
  status         String
  packageJson    String   @db.Text
  simulationJson String?  @db.Text
  settlementJson String?  @db.Text
  fundTxHash     String?
  fundTxLabel    String?
  programId      String?
  evidenceJson   String?  @db.Text
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([communitySlug, createdAt])
  @@index([userId, communitySlug])
  @@index([status])
}

model ResolveEcosystem {
  id             String                    @id @default(cuid())
  userId         String
  user           User                      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name           String
  kind           String                    @default("organization")
  keywordsJson   String                    @default("[]")
  reposJson      String                    @default("[]")
  connectorsJson String                    @default("[]")
  metadataJson   String?
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  missions       ResolveMission[]
  timeline       ResolveTimelineEvent[]
  knowledge      ResolveKnowledgeEntry[]
  installs       ResolveCommunityInstall[]

  @@unique([userId, name])
  @@index([userId])
}

/// RESOLVE installed on a canonical community (Discover → Install → Operate)
model ResolveCommunityInstall {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  communitySlug    String
  ecosystemId      String?
  ecosystem        ResolveEcosystem?       @relation(fields: [ecosystemId], references: [id], onDelete: SetNull)
  status           String                  @default("active")
  connectorIdsJson String                  @default("[]")
  doctrineJson     String?
  installedAt      DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  programs         ResolveProgram[]
  automationRules  ResolveAutomationRule[]

  @@unique([userId, communitySlug])
  @@index([communitySlug])
  @@index([userId])
}

/// Operational program — budget, rules, verification, settlement
model ResolveProgram {
  id               String                  @id @default(cuid())
  userId           String
  user             User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  installId        String
  install          ResolveCommunityInstall @relation(fields: [installId], references: [id], onDelete: Cascade)
  templateId       String                  @default("user-centric-royalties")
  name             String
  status           String                  @default("draft")
  budgetUsd        Float                   @default(0)
  rulesJson        String                  @default("{}")
  recipientsJson   String                  @default("[]")
  missionId        String?
  lastDeployAt     DateTime?
  lastSettlementId String?
  metadataJson     String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  fundStakes       CommunityFundStake[]
  automationRules  ResolveAutomationRule[]

  @@index([userId])
  @@index([installId])
  @@index([missionId])
  @@index([status])
}

/// External or operator capital staked on a community program — yield tracked via verified impact
model CommunityFundStake {
  id                    String         @id @default(cuid())
  programId             String
  program               ResolveProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  userId                String
  user                  User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  principalUsd          Float
  releasedUsd           Float          @default(0)
  impactAttributedUsd   Float          @default(0)
  targetYieldMultiplier Float          @default(2)
  status                String         @default("active")
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt

  @@index([programId])
  @@index([userId])
  @@index([status])
}

/// Persisted, non-financial benefits earned from a confirmed community-pool deposit.
model SupporterBenefitLedger {
  id                      String    @id @default(cuid())
  stakeId                 String
  programId               String
  userId                  String
  benefitKey              String
  benefitLabel            String
  status                  String    @default("pending")
  policyVersion           String?
  activationCheckpointUsd Float?
  policySnapshot          Json
  limitations             Json?
  activatedAt             DateTime?
  expiresAt               DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@unique([stakeId, benefitKey])
  @@index([userId, status, createdAt])
  @@index([programId, status])
  @@index([stakeId])
}

/// One-click automation rule — when sensor event → authorize → notify
model ResolveAutomationRule {
  id            String                  @id @default(cuid())
  userId        String
  user          User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  installId     String
  install       ResolveCommunityInstall @relation(fields: [installId], references: [id], onDelete: Cascade)
  programId     String?
  program       ResolveProgram?         @relation(fields: [programId], references: [id], onDelete: SetNull)
  communitySlug String
  name          String
  triggerEvent  String
  authorizeUsd  Float
  notifyChannel String                  @default("email")
  notifyTarget  String
  enabled       Boolean                 @default(true)
  lastFiredAt   DateTime?
  lastFiredMeta String?
  createdAt     DateTime                @default(now())
  updatedAt     DateTime                @updatedAt

  @@index([installId])
  @@index([userId])
  @@index([communitySlug])
  @@index([enabled])
}

model ResolveKnowledgeEntry {
  id          String            @id @default(cuid())
  userId      String
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  kind        String            @default("mission")
  summary     String            @db.Text
  contentJson String?           @db.Text
  source      String?
  ecosystemId String?
  ecosystem   ResolveEcosystem? @relation(fields: [ecosystemId], references: [id], onDelete: SetNull)
  missionId   String?
  mission     ResolveMission?   @relation(fields: [missionId], references: [id], onDelete: SetNull)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  @@index([userId, updatedAt])
  @@index([ecosystemId])
}

model ResolveTimelineEvent {
  id           String            @id @default(cuid())
  userId       String
  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  ecosystemId  String?
  ecosystem    ResolveEcosystem? @relation(fields: [ecosystemId], references: [id], onDelete: SetNull)
  missionId    String?
  mission      ResolveMission?   @relation(fields: [missionId], references: [id], onDelete: SetNull)
  eventType    String
  title        String
  detail       String?           @db.Text
  severity     String            @default("info")
  metadataJson String?
  createdAt    DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([ecosystemId, createdAt])
  @@index([missionId])
}

/// Background GitHub OSS scan — written by cron, read by Discover APIs.
model GithubOssScan {
  id            String   @id @default(cuid())
  owner         String
  repo          String
  fullName      String
  payloadJson   String   @db.Text
  stars         Int      @default(0)
  fundingGapUsd Float    @default(0)
  priority      String   @default("medium")
  scannedAt     DateTime @default(now())

  @@unique([owner, repo])
  @@index([scannedAt])
}

/// Immutable GitHub repository snapshots used for deterministic Discover deltas.
model DiscoverRepositorySnapshot {
  id          String   @id @default(cuid())
  owner       String
  repo        String
  fullName    String
  fingerprint String
  payload     Json
  observedAt  DateTime
  createdAt   DateTime @default(now())

  @@unique([fullName, fingerprint])
  @@index([fullName, observedAt])
  @@index([observedAt])
}

/// Per-user earnings aggregate — refreshed on cron and after ledger writes.
model UserEarningsSnapshot {
  userId             String    @id
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  youEarnedUsd       Float     @default(0)
  claimableUsd       Float     @default(0)
  authorizedUsd      Float     @default(0)
  settledUsd         Float     @default(0)
  pendingUsd         Float     @default(0)
  authorizationCount Int       @default(0)
  identitiesJson     String    @default("[]") @db.Text
  stalestClaimableAt DateTime?
  notifyUrgency      Float     @default(0)
  githubLinked       Boolean   @default(false)
  computedAt         DateTime  @default(now())

  @@index([computedAt])
}

/// Community vitals aggregate — one row per catalog slug.
model CommunityVitalsSnapshot {
  slug        String   @id
  payloadJson String   @db.Text
  computedAt  DateTime @default(now())

  @@index([computedAt])
}

/// Canonical wallet inventory for human, treasury, and agent-controlled wallets.
model Wallet {
  id               String   @id @default(cuid())
  userId           String?
  ownerType        String
  custodyType      String
  provider         String
  providerWalletId String?
  network          String
  address          String
  status           String   @default("active")
  spendingPolicy   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@unique([provider, network, address])
  @@index([userId, ownerType])
  @@index([providerWalletId])
}

model PayoutDestination {
  id         String    @id @default(cuid())
  userId     String?
  identityId String?
  walletId   String?
  network    String
  address    String
  asset      String    @default("USDC")
  status     String    @default("pending")
  proofJson  Json?
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([userId, status])
  @@index([identityId])
  @@index([network, address])
}

model SourceConnection {
  id                String    @id @default(cuid())
  userId            String
  communitySlug     String?
  provider          String
  externalAccountId String?
  displayLabel      String?
  status            String    @default("connected")
  capabilitiesJson  Json?
  secretRef         String?
  authExpiresAt     DateTime?
  lastSyncedAt      DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@unique([userId, provider, externalAccountId])
  @@index([userId, status])
  @@index([communitySlug, status])
}

model SourceSyncRun {
  id                 String    @id @default(cuid())
  sourceConnectionId String
  communitySlug      String?
  status             String    @default("queued")
  cursor             String?
  evidenceCount      Int       @default(0)
  startedAt          DateTime?
  completedAt        DateTime?
  errorCode          String?
  errorMessage       String?
  metadata           Json?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([sourceConnectionId, createdAt])
  @@index([communitySlug, status])
}

model Evidence {
  id                 String   @id @default(cuid())
  sourceConnectionId String?
  syncRunId          String?
  communitySlug      String?
  externalId         String
  kind               String
  subjectRef         String
  actorRef           String?
  occurredAt         DateTime
  contentHash        String
  sourceUrl          String?
  payload            Json
  confidencePpm      Int      @default(1000000)
  createdAt          DateTime @default(now())

  @@unique([kind, externalId, contentHash])
  @@index([communitySlug, occurredAt])
  @@index([subjectRef])
  @@index([actorRef])
}

model Identity {
  id            String    @id @default(cuid())
  userId        String?
  communitySlug String?
  canonicalRef  String    @unique
  displayName   String?
  status        String    @default("observed")
  confidencePpm Int       @default(0)
  evidenceIds   String[]  @default([])
  metadata      Json?
  verifiedAt    DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([userId, status])
  @@index([communitySlug, status])
}

model ObservedIdentity {
  id                  String   @id @default(cuid())
  userId              String
  communitySlug       String
  provider            String
  externalRef         String
  displayLabel        String?
  status              String   @default("observed")
  evidenceIds         String[] @default([])
  payoutDestinationId String?
  firstObservedAt     DateTime @default(now())
  lastObservedAt      DateTime @default(now())
  metadata            Json?

  @@unique([userId, communitySlug, provider, externalRef])
  @@index([userId, communitySlug, status])
  @@index([communitySlug, status])
  @@index([externalRef])
}

model IdentityCandidate {
  id                 String   @id @default(cuid())
  observedIdentityId String
  identityId         String?
  candidateRef       String
  displayName        String?
  confidencePpm      Int
  confidenceFactors  Json
  contradictingData  Json?
  modelProvider      String?
  modelVersion       String?
  status             String   @default("suggested")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([observedIdentityId, candidateRef])
  @@index([observedIdentityId, status])
  @@index([identityId])
}

model IdentityResolution {
  id                 String   @id @default(cuid())
  observedIdentityId String
  candidateId        String?
  identityId         String?
  action             String
  method             String
  resolvedBy         String
  evidenceIds        String[] @default([])
  previousState      String
  newState           String
  modelProvider      String?
  modelVersion       String?
  note               String?
  createdAt          DateTime @default(now())

  @@index([observedIdentityId, createdAt])
  @@index([identityId])
  @@index([resolvedBy, createdAt])
}

model IdentityClaim {
  id                 String    @id @default(cuid())
  observedIdentityId String
  userId             String
  status             String    @default("submitted")
  evidenceIds        String[]  @default([])
  note               String?
  reviewedBy         String?
  reviewedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@unique([observedIdentityId, userId])
  @@index([userId, status])
  @@index([observedIdentityId, status])
}

model ProgramVersion {
  id        String   @id @default(cuid())
  programId String
  version   Int
  status    String   @default("draft")
  snapshot  Json
  createdBy String?
  createdAt DateTime @default(now())

  @@unique([programId, version])
  @@index([programId, status])
}

model PolicyVersion {
  id               String   @id @default(cuid())
  programVersionId String
  version          Int
  evidenceRule     Json
  eligibilityRule  Json
  allocationRule   Json
  settlementRule   Json
  contentHash      String
  createdBy        String?
  createdAt        DateTime @default(now())

  @@unique([programVersionId, version])
  @@index([contentHash])
}

model Obligation {
  id                  String   @id @default(cuid())
  userId              String
  communitySlug       String
  programVersionId    String
  policyVersionId     String
  identityId          String?
  payoutDestinationId String?
  evidenceIds         String[] @default([])
  amountUsdcMicro     BigInt
  status              String   @default("recognized")
  blockerCode         String?
  settlementBatchId   String?
  lineageHash         String
  recognizedAt        DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@unique([lineageHash])
  @@index([communitySlug, status])
  @@index([userId, communitySlug, status])
  @@index([programVersionId, status])
  @@index([identityId])
}

model Blueprint {
  id                          String   @id @default(cuid())
  userId                      String?
  missionId                   String
  communitySlug               String?
  programId                   String?
  version                     Int
  status                      String   @default("draft")
  objective                   Json
  evidenceIds                 String[] @default([])
  payees                      Json
  policy                      Json
  fundingRequirementUsdcMicro BigInt
  settlementPath              Json
  contentHash                 String
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  @@unique([missionId, version])
  @@index([communitySlug, status])
  @@index([contentHash])
}

model Simulation {
  id                  String   @id @default(cuid())
  blueprintId         String
  version             Int
  status              String   @default("completed")
  inputHash           String
  result              Json
  totalUsdcMicro      BigInt
  fundingGapUsdcMicro BigInt
  createdAt           DateTime @default(now())

  @@unique([blueprintId, version])
  @@index([inputHash])
}

model FundingIntent {
  id              String    @id @default(cuid())
  userId          String
  blueprintId     String?
  communitySlug   String?
  programId       String?
  amountUsdcMicro BigInt
  status          String    @default("draft")
  idempotencyKey  String    @unique
  returnTo        String?
  expiresAt       DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
  @@index([communitySlug, status])
}

model SettlementBatch {
  id              String    @id @default(cuid())
  userId          String
  communitySlug   String?
  fundingIntentId String?
  status          String    @default("prepared")
  totalUsdcMicro  BigInt
  payeeCount      Int
  idempotencyKey  String    @unique
  simulationId    String?
  preparedPackage Json
  submittedAt     DateTime?
  confirmedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([userId, status])
  @@index([communitySlug, status])
}

model ChainTransaction {
  id                    String    @id @default(cuid())
  settlementBatchId     String?
  fundingIntentId       String?
  provider              String
  providerTransactionId String?
  chainId               Int
  txHash                String?
  fromAddress           String?
  toAddress             String?
  amountUsdcMicro       BigInt?
  status                String    @default("submitted")
  blockNumber           BigInt?
  failureCode           String?
  failureMessage        String?
  submittedAt           DateTime  @default(now())
  confirmedAt           DateTime?
  updatedAt             DateTime  @updatedAt

  @@unique([chainId, txHash])
  @@index([settlementBatchId, status])
  @@index([fundingIntentId, status])
  @@index([providerTransactionId])
}

model Receipt {
  id                 String   @id @default(cuid())
  settlementBatchId  String
  chainTransactionId String
  communitySlug      String?
  publicReference    String   @unique
  totalUsdcMicro     BigInt
  payeeCount         Int
  payload            Json
  issuedAt           DateTime @default(now())

  @@unique([settlementBatchId])
  @@index([communitySlug, issuedAt])
}

model OperationalEvent {
  id             String   @id @default(cuid())
  eventType      String
  aggregateType  String
  aggregateId    String
  userId         String?
  communitySlug  String?
  correlationId  String
  idempotencyKey String   @unique
  payload        Json
  occurredAt     DateTime @default(now())
  createdAt      DateTime @default(now())

  @@index([aggregateType, aggregateId, occurredAt])
  @@index([userId, occurredAt])
  @@index([communitySlug, occurredAt])
  @@index([correlationId])
}

model OutboxEvent {
  id                 String    @id @default(cuid())
  operationalEventId String    @unique
  topic              String
  aggregateType      String
  aggregateId        String
  payload            Json
  status             String    @default("pending")
  attemptCount       Int       @default(0)
  availableAt        DateTime  @default(now())
  processedAt        DateTime?
  lastError          String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([status, availableAt])
  @@index([aggregateType, aggregateId])
}

model WebhookEvent {
  id              String    @id @default(cuid())
  provider        String
  providerEventId String
  eventType       String
  signatureValid  Boolean
  status          String    @default("received")
  payload         Json
  receivedAt      DateTime  @default(now())
  processedAt     DateTime?
  errorMessage    String?

  @@unique([provider, providerEventId])
  @@index([provider, status, receivedAt])
}

model IdempotencyRecord {
  key         String    @id
  scope       String
  userId      String?
  requestHash String
  status      String    @default("started")
  response    Json?
  errorCode   String?
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([scope, userId, createdAt])
  @@index([status, expiresAt])
}

/// Canonical creator work that can be promoted through an Outcome Campaign.
model CreatorAsset {
  id                  String    @id @default(cuid())
  ownerUserId         String
  type                String
  canonicalUrl        String
  title               String
  description         String?
  sourceAdapterId     String
  externalId          String?
  ownershipState      String    @default("unverified")
  ownershipChallenge  String?
  ownershipProof      Json?
  ownershipVerifiedAt DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([ownerUserId, canonicalUrl])
  @@index([ownerUserId, ownershipState])
}

model OutcomeCampaign {
  id                      String    @id @default(cuid())
  creatorUserId           String
  assetId                 String
  name                    String
  objective               String    @db.Text
  contributionType        String
  verificationAdapterId   String
  status                  String    @default("draft")
  totalBudgetMicroUsdc    BigInt
  committedMicroUsdc      BigInt    @default(0)
  recognizedMicroUsdc     BigInt    @default(0)
  settledMicroUsdc        BigInt    @default(0)
  participantCapMicroUsdc BigInt?
  startsAt                DateTime
  endsAt                  DateTime?
  activePolicyVersionId   String?
  fundingIntentId         String?
  blueprintId             String?
  simulationId            String?
  approvedAt              DateTime?
  publishedAt             DateTime?
  closedAt                DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt

  @@index([creatorUserId, status])
  @@index([status, startsAt, endsAt])
  @@index([assetId])
}

model CampaignParticipant {
  id         String   @id @default(cuid())
  campaignId String
  userId     String
  identityId String?
  status     String   @default("joined")
  joinedAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([campaignId, userId])
  @@index([userId, status])
}

model WorkSubmission {
  id                   String    @id @default(cuid())
  campaignId           String
  participantId        String
  userId               String
  workUrl              String
  sourceReference      String?
  status               String    @default("submitted")
  latestSnapshotId     String?
  latestOutcomeEventId String?
  identityChallenge    String?
  identityProof        Json?
  identityVerifiedAt   DateTime?
  submittedAt          DateTime  @default(now())
  withdrawnAt          DateTime?
  updatedAt            DateTime  @updatedAt

  @@unique([campaignId, workUrl])
  @@index([userId, status])
  @@index([campaignId, status])
}

model OutcomeSnapshot {
  id             String   @id @default(cuid())
  submissionId   String
  adapterId      String
  sourceObjectId String
  unitType       String
  value          BigInt
  contentHash    String
  observedAt     DateTime
  createdAt      DateTime @default(now())

  @@unique([submissionId, contentHash])
  @@index([submissionId, observedAt])
}

model OutcomeEvent {
  id               String   @id @default(cuid())
  adapterId        String
  sourceEventId    String
  campaignId       String
  submissionId     String
  type             String
  actorIdentityId  String?
  objectUrl        String
  objectLabel      String
  unitType         String
  unitValue        BigInt
  baselineValue    BigInt?
  currentValue     BigInt?
  incrementalValue BigInt?
  evidenceState    String
  recognitionState String   @default("unreviewed")
  contentHash      String
  observedAt       DateTime
  synchronizedAt   DateTime
  createdAt        DateTime @default(now())

  @@unique([adapterId, sourceEventId])
  @@index([campaignId, recognitionState])
  @@index([submissionId, observedAt])
}

model OutcomeEvidence {
  id             String   @id @default(cuid())
  outcomeEventId String
  evidenceId     String?
  provider       String
  sourceUrl      String
  state          String
  payload        Json
  contentHash    String
  createdAt      DateTime @default(now())

  @@unique([outcomeEventId, contentHash])
  @@index([outcomeEventId, state])
}

model RecognitionPolicyVersion {
  id                      String    @id @default(cuid())
  campaignId              String
  version                 Int
  formula                 Json
  evidenceRequirements    Json
  identityRequirements    Json
  reviewDelaySeconds      Int
  participantCapMicroUsdc BigInt?
  campaignCapMicroUsdc    BigInt
  contentHash             String
  activeFrom              DateTime
  supersededAt            DateTime?
  createdAt               DateTime  @default(now())

  @@unique([campaignId, version])
  @@index([campaignId, activeFrom])
  @@index([contentHash])
}

model EarningsLedgerEntry {
  id              String   @id @default(cuid())
  userId          String
  campaignId      String
  submissionId    String?
  obligationId    String?
  receiptId       String?
  type            String
  state           String
  amountMicroUsdc BigInt
  referenceHash   String   @unique
  createdAt       DateTime @default(now())

  @@index([userId, state, createdAt])
  @@index([campaignId, createdAt])
}

model CampaignFundingRequirement {
  id              String   @id @default(cuid())
  campaignId      String   @unique
  fundingIntentId String?
  amountMicroUsdc BigInt
  status          String   @default("draft")
  contentHash     String   @unique
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model FraudReview {
  id           String    @id @default(cuid())
  submissionId String
  state        String    @default("not_required")
  reasons      Json
  reviewedBy   String?
  reviewedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([submissionId])
  @@index([state, createdAt])
}

model ActionRun {
  id                   String    @id @default(cuid())
  userId               String?
  actionId             String
  aggregateType        String
  aggregateId          String?
  idempotencyKey       String    @unique
  state                String    @default("validating")
  recommendationReason String
  input                Json
  output               Json?
  errorCode            String?
  errorMessage         String?
  startedAt            DateTime  @default(now())
  completedAt          DateTime?

  @@index([userId, startedAt])
  @@index([aggregateType, aggregateId, startedAt])
  @@index([actionId, state])
}
