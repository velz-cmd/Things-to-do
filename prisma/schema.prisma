generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Task {
  id              String   @id @default(cuid())
  userId          String?
  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  title           String
  category        String   @default("money_recovery")
  targetValueUsd  Float
  successFeeUsd   Float    @default(0.5)
  budgetUsd       Float    @default(1.0)
  status          String   @default("created")
  merchantId      String?
  userWallet      String?
  escrowTxHash    String?
  escrowTaskId    Int?
  escrowLocked    Boolean  @default(false)
  proofHash       String?
  settlementTxHash String?
  recoveredUsd    Float    @default(0)
  executionCostUsd Float   @default(0)
  currentAgent    String?
  nextRunAt       DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  events          TaskEvent[]
  proofs          Proof[]
  microPayments   MicroPayment[]
}

model TaskEvent {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  agent     String
  phase     String
  message   String
  metadata  String?
  createdAt DateTime @default(now())
}

model Proof {
  id           String   @id @default(cuid())
  taskId       String
  task         Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  type         String
  source       String
  payload      String
  contentHash  String
  artifactUrl  String?
  verified     Boolean  @default(false)
  createdAt    DateTime @default(now())
}

model MicroPayment {
  id        String   @id @default(cuid())
  taskId    String
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  purpose   String
  amountUsd Float
  txHash    String?
  createdAt DateTime @default(now())
}

model Stats {
  id                    Int @id @default(1)
  moneyRecoveredUsd     Float @default(0)
  tasksCompleted        Int   @default(0)
  executionCostUsd      Float @default(0)
  subscriptionsCancelled Int  @default(0)
}

model User {
  id              String   @id
  email           String?
  displayName     String?
  authProvider    String   @default("wallet")
  walletAddress   String?
  embeddedWallet  Boolean  @default(false)
  availableUsd    Float    @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  tasks           Task[]
  transactions    WalletTransaction[]
}

model WalletTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  method    String?
  amountUsd Float
  status    String   @default("completed")
  label     String?
  createdAt DateTime @default(now())
}
