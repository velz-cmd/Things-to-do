# Copy to scripts/navidrome-bridge.local.env (gitignored) on your Navidrome host.
# Windows (WSL): NAVIDROME_DB_PATH=/mnt/c/ProgramData/Navidrome/navidrome.db

NAVIDROME_DB_PATH=/mnt/c/ProgramData/Navidrome/navidrome.db
RESOLVE_SYNC_URL=https://resolve-task.vercel.app/api/connectors/navidrome/sync
NAVIDROME_SYNC_SECRET=your-sync-secret-from-vercel
NAVIDROME_PROGRAM_MISSION_ID=program-your-install-mission-id
# Optional:
# NAVIDROME_INSTANCE_ID=default
# NAVIDROME_PER_PLAY_USD=0.0004
# NAVIDROME_BRIDGE_BATCH=200
