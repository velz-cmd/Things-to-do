# Copy this file to the repo root as jellyfin-bridge.env (same folder as package.json)
# Windows: copy scripts\jellyfin-bridge.env.example jellyfin-bridge.env

JELLYFIN_URL=http://localhost:8096
JELLYFIN_API_KEY=your-api-key-from-jellyfin-dashboard
RESOLVE_USER_ID=your-user-id-from-profile-or-api-profile-me
RESOLVE_SYNC_URL=https://resolve-self.vercel.app/api/connectors/jellyfin/sync
JELLYFIN_SYNC_SECRET=your-vercel-CRON_SECRET
